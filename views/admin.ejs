<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin — SwiftFreight</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0a0f1e; --navy2: #111827; --orange: #f97316;
      --orange2: #ea580c; --slate: #1e293b; --white: #ffffff;
      --green: #22c55e; --red: #ef4444; --yellow: #eab308;
    }
    body { font-family: 'DM Sans', sans-serif; background: var(--navy2); color: var(--white); min-height: 100vh; }

    /* TOP NAV */
    .topnav {
      background: var(--navy); border-bottom: 1px solid rgba(255,255,255,0.07);
      padding: 14px 20px; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 200;
    }
    .topnav-logo { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 900; }
    .topnav-logo span { color: var(--orange); }
    .topnav-right { display: flex; align-items: center; gap: 10px; }
    .topnav-badge { font-size: 11px; color: var(--orange); background: rgba(249,115,22,0.1); border: 1px solid rgba(249,115,22,0.2); padding: 4px 10px; border-radius: 20px; }
    .topnav-home { font-size: 12px; color: rgba(255,255,255,0.5); text-decoration: none; background: rgba(255,255,255,0.06); padding: 5px 12px; border-radius: 6px; transition: all 0.2s; }
    .topnav-home:hover { color: white; background: rgba(255,255,255,0.1); }

    /* TAB BAR */
    .tab-bar { display: flex; background: var(--navy); border-bottom: 1px solid rgba(255,255,255,0.07); overflow-x: auto; }
    .tab-bar::-webkit-scrollbar { display: none; }
    .tab-btn {
      flex: 1; min-width: 72px; padding: 13px 6px;
      background: none; border: none; color: rgba(255,255,255,0.4);
      font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 600;
      cursor: pointer; text-align: center; border-bottom: 2px solid transparent;
      transition: all 0.2s; white-space: nowrap;
    }
    .tab-btn.active { color: var(--orange); border-bottom-color: var(--orange); }
    .tab-icon { font-size: 17px; display: block; margin-bottom: 3px; }

    /* PAGES */
    .page { display: none; padding: 18px; }
    .page.active { display: block; }

    /* STATS */
    .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 18px; }
    .stat-card { background: var(--slate); border: 1px solid rgba(255,255,255,0.07); border-radius: 12px; padding: 16px; }
    .stat-label { font-size: 10px; color: rgba(255,255,255,0.35); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
    .stat-num { font-family: 'Barlow Condensed', sans-serif; font-size: 34px; font-weight: 900; }
    .stat-num.orange { color: var(--orange); }
    .stat-num.green { color: var(--green); }

    /* SECTION TITLE */
    .sec-title { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 700; margin-bottom: 14px; }

    /* CARD */
    .card { background: var(--slate); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 18px; margin-bottom: 14px; }

    /* FORM */
    .fg { margin-bottom: 13px; }
    .flabel { display: block; font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 6px; }
    .finput {
      width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px; padding: 12px 14px; color: var(--white);
      font-family: 'DM Sans', sans-serif; font-size: 15px; outline: none;
      transition: border-color 0.2s; -webkit-appearance: none;
    }
    .finput:focus { border-color: var(--orange); background: rgba(249,115,22,0.05); }
    select.finput option { background: var(--slate); }

    .btn { width: 100%; padding: 14px; border: none; border-radius: 10px; font-family: 'Barlow Condensed', sans-serif; font-size: 18px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
    .btn-primary { background: var(--orange); color: var(--white); }
    .btn-primary:hover { background: var(--orange2); }
    .btn-primary:disabled { opacity: 0.55; }

    /* ALERT */
    .alert { padding: 11px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 12px; display: none; }
    .alert.success { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: var(--green); }
    .alert.error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: var(--red); }

    /* MAP */
    #adminMap { height: 290px; border-radius: 10px; width: 100%; margin-bottom: 10px; }
    .coord-box { padding: 10px 13px; border-radius: 8px; background: rgba(249,115,22,0.08); border: 1px solid rgba(249,115,22,0.2); font-size: 13px; color: var(--orange); margin-bottom: 12px; }

    /* SHIPMENT CARDS */
    .ship-card { background: var(--slate); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 16px; margin-bottom: 12px; }
    .ship-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
    .ship-num { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 700; }
    .pill { padding: 4px 11px; border-radius: 20px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .pill-transit { background: rgba(249,115,22,0.15); color: var(--orange); }
    .pill-delivered { background: rgba(34,197,94,0.15); color: var(--green); }
    .pill-pending { background: rgba(234,179,8,0.15); color: var(--yellow); }
    .ship-detail { font-size: 12px; color: rgba(255,255,255,0.45); margin-bottom: 3px; }
    .ship-actions { display: flex; gap: 8px; margin-top: 12px; }
    .action-btn {
      flex: 1; padding: 9px 6px; background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
      color: rgba(255,255,255,0.65); font-size: 12px; font-weight: 500;
      cursor: pointer; text-align: center; transition: all 0.2s;
      font-family: 'DM Sans', sans-serif;
    }
    .action-btn:hover { border-color: var(--orange); color: var(--orange); background: rgba(249,115,22,0.08); }
    .action-btn.del:hover { border-color: var(--red); color: var(--red); background: rgba(239,68,68,0.08); }

    /* CONFIRM OVERLAY */
    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 999; align-items: center; justify-content: center; padding: 20px; }
    .overlay.show { display: flex; }
    .confirm-box { background: var(--slate); border-radius: 16px; padding: 28px; width: 100%; max-width: 320px; text-align: center; }
    .confirm-box h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 24px; margin-bottom: 8px; }
    .confirm-box p { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 22px; line-height: 1.5; }
    .confirm-btns { display: flex; gap: 10px; }
    .confirm-btns button { flex: 1; padding: 12px; border: none; border-radius: 8px; font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 700; cursor: pointer; }
    .cbtn-cancel { background: rgba(255,255,255,0.08); color: var(--white); }
    .cbtn-delete { background: var(--red); color: var(--white); }

    /* QUICK PANEL */
    .panel { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 998; align-items: flex-end; justify-content: center; }
    .panel.show { display: flex; }
    .panel-inner { background: var(--navy2); border-radius: 20px 20px 0 0; padding: 22px 18px; width: 100%; max-width: 500px; max-height: 92vh; overflow-y: auto; }
    .panel-title { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 700; margin-bottom: 6px; }
    .panel-sub { font-size: 12px; color: rgba(255,255,255,0.4); margin-bottom: 14px; }
    #quickMap { height: 250px; border-radius: 10px; width: 100%; margin-bottom: 10px; }
    .panel-btns { display: flex; gap: 10px; }
    .pbtn { flex: 1; padding: 13px; border: none; border-radius: 8px; font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 700; cursor: pointer; }
    .pbtn-cancel { background: rgba(255,255,255,0.08); color: white; }
    .pbtn-save { background: var(--orange); color: white; }

    /* EMPTY STATE */
    .empty-state { text-align: center; padding: 48px 20px; color: rgba(255,255,255,0.25); }
    .empty-state p:first-child { font-size: 40px; margin-bottom: 10px; }
  </style>
</head>
<body>

<div class="topnav">
  <div class="topnav-logo">Swift<span>Freight</span></div>
  <div class="topnav-right">
    <div class="topnav-badge">🔐 Admin</div>
    <a href="/" class="topnav-home">← Site</a>
  </div>
</div>

<div class="tab-bar">
  <button class="tab-btn active" onclick="showTab('dashboard', this)"><span class="tab-icon">📊</span>Dashboard</button>
  <button class="tab-btn" onclick="showTab('add', this)"><span class="tab-icon">➕</span>Add</button>
  <button class="tab-btn" onclick="showTab('location', this)"><span class="tab-icon">📍</span>Location</button>
  <button class="tab-btn" onclick="showTab('shipments', this)"><span class="tab-icon">📦</span>Shipments</button>
</div>

<!-- DASHBOARD -->
<div class="page active" id="tab-dashboard">
  <div class="stats-grid">
    <div class="stat-card"><div class="stat-label">Total</div><div class="stat-num"><%= typeof shipments !== 'undefined' ? shipments.length : 0 %></div></div>
    <div class="stat-card"><div class="stat-label">In Transit</div><div class="stat-num orange"><%= typeof shipments !== 'undefined' ? shipments.filter(s=>(s.status||'').toLowerCase().includes('transit')).length : 0 %></div></div>
    <div class="stat-card"><div class="stat-label">Delivered</div><div class="stat-num green"><%= typeof shipments !== 'undefined' ? shipments.filter(s=>(s.status||'').toLowerCase().includes('deliver')).length : 0 %></div></div>
    <div class="stat-card"><div class="stat-label">Pending</div><div class="stat-num"><%= typeof shipments !== 'undefined' ? shipments.filter(s=>(s.status||'').toLowerCase().includes('pending')).length : 0 %></div></div>
  </div>
  <div class="card">
    <div style="font-size:14px;color:rgba(255,255,255,0.5);line-height:2;">
      <p>👋 Welcome to your Admin Panel</p>
      <p>➕ <b style="color:white">Add</b> — Create new shipments</p>
      <p>📍 <b style="color:white">Location</b> — Update shipment on map</p>
      <p>📦 <b style="color:white">Shipments</b> — View, edit or delete</p>
      <br>
      <p style="font-size:11px;color:rgba(255,255,255,0.25);">Secret admin URL: /swiftadmin2026</p>
    </div>
  </div>
</div>

<!-- ADD SHIPMENT -->
<div class="page" id="tab-add">
  <div class="sec-title">➕ New Shipment</div>
  <div class="alert" id="addAlert"></div>
  <div class="card">
    <form id="addForm">
      <div class="fg"><label class="flabel">Tracking Number *</label><input class="finput" name="tracking_number" placeholder="e.g. SWF-2026-00001" required/></div>
      <div class="fg"><label class="flabel">Recipient Name</label><input class="finput" name="recipient_name" placeholder="Customer full name"/></div>
      <div class="fg"><label class="flabel">Sender Name</label><input class="finput" name="sender_name" placeholder="Sender full name"/></div>
      <div class="fg"><label class="flabel">Origin</label><input class="finput" name="origin" placeholder="e.g. Lagos, Nigeria"/></div>
      <div class="fg"><label class="flabel">Destination</label><input class="finput" name="destination" placeholder="e.g. London, UK"/></div>
      <div class="fg">
        <label class="flabel">Status</label>
        <select class="finput" name="status">
          <option value="Pending">Pending</option>
          <option value="In Transit">In Transit</option>
          <option value="Out for Delivery">Out for Delivery</option>
          <option value="Delivered">Delivered</option>
        </select>
      </div>
      <div class="fg">
        <label class="flabel">Service Type</label>
        <select class="finput" name="service_type">
          <option value="Express Air">Express Air</option>
          <option value="Standard Air">Standard Air</option>
          <option value="Ocean Freight">Ocean Freight</option>
          <option value="Road Freight">Road Freight</option>
        </select>
      </div>
      <div class="fg"><label class="flabel">Weight (kg)</label><input class="finput" name="weight" type="number" step="0.1" placeholder="0.0"/></div>
      <div class="fg"><label class="flabel">Est. Delivery Date</label><input class="finput" name="estimated_delivery" type="date"/></div>
      <button type="submit" class="btn btn-primary">Create Shipment →</button>
    </form>
  </div>
</div>

<!-- LOCATION -->
<div class="page" id="tab-location">
  <div class="sec-title">📍 Update Location</div>
  <div class="alert" id="locAlert"></div>
  <div class="card">
    <div class="fg"><label class="flabel">Tracking Number</label><input class="finput" id="locTracking" placeholder="e.g. SWF-2026-00001"/></div>
    <div class="fg"><label class="flabel">Location Name</label><input class="finput" id="locName" placeholder="e.g. Dubai Sorting Hub"/></div>
    <div class="fg">
      <label class="flabel">Update Status (optional)</label>
      <select class="finput" id="locStatus">
        <option value="">— Keep current —</option>
        <option value="Pending">Pending</option>
        <option value="In Transit">In Transit</option>
        <option value="Out for Delivery">Out for Delivery</option>
        <option value="Delivered">Delivered</option>
      </select>
    </div>
  </div>
  <p style="font-size:12px;color:rgba(255,255,255,0.35);text-align:center;margin-bottom:8px;">👆 Tap the map to drop pin</p>
  <div id="adminMap"></div>
  <div class="coord-box" id="coordBox">📍 Tap on the map to set location</div>
  <button class="btn btn-primary" onclick="saveLocation()">💾 Save Location</button>
</div>

<!-- SHIPMENTS -->
<div class="page" id="tab-shipments">
  <div class="sec-title">📦 All Shipments</div>
  <% if (typeof shipments !== 'undefined' && shipments.length > 0) { %>
    <% shipments.forEach(function(s) { %>
      <%
        const sc = (s.status||'').toLowerCase();
        const pc = sc.includes('transit') ? 'pill-transit' : sc.includes('deliver') ? 'pill-delivered' : 'pill-pending';
      %>
      <div class="ship-card">
        <div class="ship-top">
          <div class="ship-num"><%= s.tracking_number %></div>
          <div class="pill <%= pc %>"><%= s.status || 'Unknown' %></div>
        </div>
        <div class="ship-detail">👤 <%= s.recipient_name || 'No recipient' %></div>
        <div class="ship-detail">📍 <%= s.origin || '—' %> → <%= s.destination || '—' %></div>
        <% if (s.estimated_delivery) { %><div class="ship-detail">📅 Est: <%= s.estimated_delivery %></div><% } %>
        <% if (s.location_name) { %><div class="ship-detail">🗺️ Last known: <%= s.location_name %></div><% } %>
        <div class="ship-actions">
          <button class="action-btn" onclick="quickLoc('<%= s.tracking_number %>')">📍 Set Location</button>
          <button class="action-btn del" onclick="confirmDel('<%= s.tracking_number %>')">🗑️ Delete</button>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div class="empty-state"><p>📭</p><p>No shipments yet</p><p style="font-size:13px;margin-top:6px;">Go to Add tab to create one</p></div>
  <% } %>
</div>

<!-- DELETE CONFIRM -->
<div class="overlay" id="confirmOverlay">
  <div class="confirm-box">
    <h3>Delete Shipment?</h3>
    <p id="confirmMsg">This cannot be undone.</p>
    <div class="confirm-btns">
      <button class="cbtn-cancel" onclick="closeConfirm()">Cancel</button>
      <button class="cbtn-delete" onclick="doDelete()">Delete</button>
    </div>
  </div>
</div>

<!-- QUICK LOCATION PANEL -->
<div class="panel" id="quickPanel">
  <div class="panel-inner">
    <div class="panel-title">📍 Set Location</div>
    <div class="panel-sub" id="panelSub">Tracking: —</div>
    <div id="quickMap"></div>
    <div class="coord-box" id="quickCoordBox">👆 Tap the map to drop pin</div>
    <div class="fg"><label class="flabel">Location Name</label><input class="finput" id="quickLocName" placeholder="e.g. Lagos Airport"/></div>
    <div class="fg">
      <label class="flabel">Update Status</label>
      <select class="finput" id="quickLocStatus">
        <option value="">— Keep current —</option>
        <option value="Pending">Pending</option>
        <option value="In Transit">In Transit</option>
        <option value="Out for Delivery">Out for Delivery</option>
        <option value="Delivered">Delivered</option>
      </select>
    </div>
    <div class="panel-btns">
      <button class="pbtn pbtn-cancel" onclick="closePanel()">Cancel</button>
      <button class="pbtn pbtn-save" onclick="saveQuickLoc()">💾 Save</button>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  // ---- TABS ----
  function showTab(name, btn) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
    if (name === 'location' && !adminMapReady) initAdminMap();
  }

  // ---- ORANGE PIN ICON ----
  function orangePin() {
    return L.divIcon({
      html: `<div style="background:#f97316;width:14px;height:14px;border-radius:50%;border:3px solid white;box-shadow:0 0 0 4px rgba(249,115,22,0.3),0 3px 10px rgba(0,0,0,0.4)"></div>`,
      className: '', iconSize: [14,14], iconAnchor: [7,7]
    });
  }

  // ---- ADMIN MAP ----
  let adminMapReady = false, selLat = null, selLng = null, adminMarker = null, adminMapObj = null;

  function initAdminMap() {
    adminMapReady = true;
    adminMapObj = L.map('adminMap').setView([9.0820, 8.6753], 4);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '© OpenStreetMap © CARTO', subdomains: 'abcd', maxZoom: 20
    }).addTo(adminMapObj);
    adminMapObj.on('click', function(e) {
      selLat = e.latlng.lat.toFixed(6);
      selLng = e.latlng.lng.toFixed(6);
      document.getElementById('coordBox').textContent = `✅ Selected: ${selLat}, ${selLng}`;
      if (adminMarker) adminMapObj.removeLayer(adminMarker);
      adminMarker = L.marker([selLat, selLng], { icon: orangePin() }).addTo(adminMapObj);
    });
  }

  // ---- SAVE LOCATION ----
  async function saveLocation() {
    const tracking = document.getElementById('locTracking').value.trim();
    const name = document.getElementById('locName').value.trim();
    const status = document.getElementById('locStatus').value;
    const al = document.getElementById('locAlert');
    if (!tracking || !selLat || !selLng) { showAlert(al, 'error', '⚠️ Enter tracking number and tap the map'); return; }
    const r = await fetch('/update-location', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ trackingNumber:tracking, lat:selLat, lng:selLng, locationName:name, status }) });
    const d = await r.json();
    if (d.success) { showAlert(al, 'success', '✅ Location saved!'); setTimeout(() => location.reload(), 1500); }
    else { showAlert(al, 'error', '❌ Tracking number not found'); }
  }

  // ---- ADD SHIPMENT ----
  document.getElementById('addForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const al = document.getElementById('addAlert');
    const data = Object.fromEntries(new FormData(this).entries());
    const r = await fetch('/add-shipment', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data) });
    const d = await r.json();
    if (d.success) { showAlert(al, 'success', '✅ Shipment created!'); this.reset(); setTimeout(() => location.reload(), 1500); }
    else { showAlert(al, 'error', '❌ ' + (d.message || 'Error. Check tracking number.')); }
  });

  // ---- DELETE ----
  let delTarget = null;
  function confirmDel(num) { delTarget = num; document.getElementById('confirmMsg').textContent = `Delete "${num}"? This cannot be undone.`; document.getElementById('confirmOverlay').classList.add('show'); }
  function closeConfirm() { document.getElementById('confirmOverlay').classList.remove('show'); delTarget = null; }
  async function doDelete() {
    if (!delTarget) return;
    const r = await fetch('/delete-shipment', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ trackingNumber: delTarget }) });
    const d = await r.json();
    if (d.success) { closeConfirm(); location.reload(); }
  }

  // ---- QUICK LOCATION ----
  let qMap = null, qMarker = null, qLat = null, qLng = null, qTracking = null;
  function quickLoc(num) {
    qTracking = num;
    document.getElementById('panelSub').textContent = 'Tracking: ' + num;
    document.getElementById('quickPanel').classList.add('show');
    setTimeout(() => {
      if (!qMap) {
        qMap = L.map('quickMap').setView([9.0820, 8.6753], 4);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { attribution:'© OpenStreetMap © CARTO', subdomains:'abcd', maxZoom:20 }).addTo(qMap);
        qMap.on('click', function(e) {
          qLat = e.latlng.lat.toFixed(6); qLng = e.latlng.lng.toFixed(6);
          document.getElementById('quickCoordBox').textContent = `✅ ${qLat}, ${qLng}`;
          if (qMarker) qMap.removeLayer(qMarker);
          qMarker = L.marker([qLat, qLng], { icon: orangePin() }).addTo(qMap);
        });
      }
      qMap.invalidateSize();
    }, 300);
  }
  function closePanel() { document.getElementById('quickPanel').classList.remove('show'); qLat = null; qLng = null; }
  async function saveQuickLoc() {
    if (!qLat || !qLng) { alert('Tap the map first'); return; }
    const name = document.getElementById('quickLocName').value.trim();
    const status = document.getElementById('quickLocStatus').value;
    const r = await fetch('/update-location', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ trackingNumber: qTracking, lat: qLat, lng: qLng, locationName: name, status }) });
    const d = await r.json();
    if (d.success) { closePanel(); location.reload(); }
    else { alert('Error. Check tracking number.'); }
  }

  // ---- HELPER ----
  function showAlert(el, type, msg) {
    el.className = 'alert ' + type; el.textContent = msg; el.style.display = 'block';
    setTimeout(() => { el.style.display = 'none'; }, 4000);
  }
</script>
</body>
</html>