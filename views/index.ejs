<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SwiftFreight — Global Logistics Since 1999</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <script type="text/javascript">
    function googleTranslateElementInit() {
      new google.translate.TranslateElement({
        pageLanguage: 'en',
        includedLanguages: 'en,fr,ar,zh-CN,es,de,pt,ru,ja,ko,hi,yo,ha,ig,sw',
        layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
        autoDisplay: false
      }, 'google_translate_element');
    }
  </script>
  <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0a0f1e; --navy2: #111827; --orange: #f97316;
      --orange2: #ea580c; --slate: #1e293b; --white: #ffffff; --green: #22c55e;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--navy); color: var(--white); overflow-x: hidden; }

    /* TRANSLATE */
    .goog-te-banner-frame { display: none !important; }
    body { top: 0 !important; }
    .skiptranslate { display: none !important; }
    .goog-te-gadget-simple {
      background: rgba(255,255,255,0.15) !important;
      border: 1px solid rgba(255,255,255,0.3) !important;
      border-radius: 4px !important; padding: 2px 8px !important;
      font-size: 11px !important; color: white !important; cursor: pointer;
    }
    .goog-te-gadget-simple span { color: white !important; }
    .goog-te-gadget-simple .goog-te-menu-value span { color: white !important; }

    /* TOP BAR */
    .top-bar {
      background: var(--orange); padding: 7px 48px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .top-bar-left { color: white; font-size: 12px; font-weight: 600; letter-spacing: 0.3px; }
    .top-bar-right { display: flex; align-items: center; gap: 20px; }
    .top-bar-link {
      color: white; text-decoration: none; font-size: 12px; font-weight: 600;
      display: flex; align-items: center; gap: 5px;
      opacity: 0.9; transition: opacity 0.2s;
    }
    .top-bar-link:hover { opacity: 1; }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 500;
      background: rgba(10,15,30,0.97);
      border-bottom: 1px solid rgba(255,255,255,0.07);
      backdrop-filter: blur(20px);
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 48px; height: 72px;
    }
    .logo-wrap { text-decoration: none; }
    .logo { font-family: 'Barlow Condensed', sans-serif; font-size: 30px; font-weight: 900; color: var(--white); line-height: 1; }
    .logo span { color: var(--orange); }
    .logo-sub { font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-top: 2px; }

    /* DESKTOP MENU */
    .desktop-menu { display: flex; align-items: center; gap: 2px; list-style: none; }
    .desktop-menu > li { position: relative; }
    .desktop-menu > li > a {
      display: flex; align-items: center; gap: 5px;
      color: rgba(255,255,255,0.7); text-decoration: none;
      font-size: 14px; font-weight: 500; padding: 8px 14px;
      border-radius: 6px; transition: all 0.2s; cursor: pointer;
    }
    .desktop-menu > li > a:hover { color: var(--white); background: rgba(255,255,255,0.06); }
    .arrow { font-size: 9px; transition: transform 0.25s; }
    .desktop-menu > li:hover .arrow { transform: rotate(180deg); }

    .dropdown {
      position: absolute; top: calc(100% + 10px); left: 0;
      background: var(--slate); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px; padding: 8px; min-width: 210px;
      opacity: 0; visibility: hidden; transform: translateY(-10px);
      transition: all 0.25s ease; z-index: 200;
      box-shadow: 0 24px 48px rgba(0,0,0,0.5);
    }
    .desktop-menu > li:hover .dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
    .dropdown a {
      display: flex; align-items: center; gap: 10px;
      color: rgba(255,255,255,0.65); text-decoration: none;
      font-size: 13px; padding: 10px 14px; border-radius: 8px; transition: all 0.15s;
    }
    .dropdown a:hover { color: var(--white); background: rgba(249,115,22,0.12); }
    .dropdown-icon { font-size: 16px; width: 22px; text-align: center; }
    .dropdown-divider { height: 1px; background: rgba(255,255,255,0.06); margin: 6px 8px; }

    .nav-right { display: flex; align-items: center; gap: 10px; }
    .nav-wa {
display: flex; align-items: center; gap: 6px;
      background: #25D366; color: white; padding: 8px 16px;
      border-radius: 6px; font-size: 13px; font-weight: 600;
      text-decoration: none; transition: background 0.2s;
    }
    .nav-wa:hover { background: #1da851; }
    .nav-track {
      background: var(--orange); color: white; padding: 8px 18px;
      border-radius: 6px; font-size: 13px; font-weight: 600;
      text-decoration: none; transition: background 0.2s;
    }
    .nav-track:hover { background: var(--orange2); }

    /* HAMBURGER */
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 6px; }
    .hamburger span { display: block; width: 24px; height: 2px; background: white; border-radius: 2px; transition: all 0.3s; }
    .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
    .hamburger.open span:nth-child(2) { opacity: 0; transform: translateX(-8px); }
    .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

    /* MOBILE MENU OVERLAY */
    .mobile-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6);
      z-index: 390; opacity: 0; transition: opacity 0.3s;
    }
    .mobile-overlay.open { opacity: 1; }

    /* MOBILE MENU PANEL */
    .mobile-menu {
      position: fixed; top: 0; right: 0; bottom: 0; width: min(320px, 85vw);
      background: var(--navy); z-index: 400; display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
      box-shadow: -20px 0 60px rgba(0,0,0,0.5);
    }
    .mobile-menu.open { transform: translateX(0); }
    .mobile-menu-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 22px; border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .mm-logo { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 900; }
    .mm-logo span { color: var(--orange); }
    .mm-close {
      background: rgba(255,255,255,0.08); border: none; color: white;
      width: 34px; height: 34px; border-radius: 50%; font-size: 16px;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
    }
    .mobile-menu-body { flex: 1; overflow-y: auto; }
    .mm-item { border-bottom: 1px solid rgba(255,255,255,0.05); }
    .mm-link, .mm-section-btn {
      display: flex; align-items: center; justify-content: space-between;
      padding: 15px 22px; color: rgba(255,255,255,0.85); text-decoration: none;
      font-size: 15px; font-weight: 500; background: none; border: none;
      width: 100%; text-align: left; cursor: pointer; transition: background 0.2s;
      gap: 10px;
    }
    .mm-link:hover, .mm-section-btn:hover { background: rgba(255,255,255,0.04); color: white; }
    .mm-link-icon { font-size: 18px; width: 24px; }
    .mm-arrow { font-size: 10px; transition: transform 0.3s; margin-left: auto; color: rgba(255,255,255,0.3); }
    .mm-arrow.open { transform: rotate(180deg); }
    .mm-sub {
      max-height: 0; overflow: hidden;
      transition: max-height 0.35s ease;
      background: rgba(0,0,0,0.2);
    }
    .mm-sub.open { max-height: 500px; }
    .mm-sub a {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 22px 12px 44px;
      color: rgba(255,255,255,0.55); text-decoration: none;
      font-size: 13px; transition: color 0.2s;
    }
    .mm-sub a:hover { color: var(--orange); }
    .mobile-menu-footer { padding: 18px 22px; border-top: 1px solid rgba(255,255,255,0.07); display: flex; flex-direction: column; gap: 10px; }
    .mm-footer-btn {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      padding: 13px; border-radius: 10px; font-size: 14px; font-weight: 600;
      text-decoration: none; transition: all 0.2s;
    }
    .mm-wa { background: #25D366; color: white; }
    .mm-wa:hover { background: #1da851; }
    .mm-email { background: var(--orange); color: white; }
    .mm-email:hover { background: var(--orange2); }

    /* HERO */
    .hero {
      min-height: 100vh; display: flex; align-items: center;
      padding: 90px 48px 80px; position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse 70% 60% at 65% 40%, rgba(249,115,22,0.13) 0%, transparent 60%),
                  radial-gradient(ellipse 50% 50% at 15% 80%, rgba(249,115,22,0.07) 0%, transparent 50%);
    }
    .hero-grid {
      position: absolute; inset: 0; opacity: 0.04;
      background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .hero-content { position: relative; z-index: 2; max-width: 640px; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(249,115,22,0.15); border: 1px solid rgba(249,115,22,0.3);
      padding: 6px 16px; border-radius: 100px; margin-bottom: 10px;
      font-size: 12px; font-weight: 600; letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--orange);
      animation: fadeUp 0.6s ease both;
    }
    .hero-badge::before { content: '●'; font-size: 8px; animation: blink 2s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
    .hero-since {
      display: flex; align-items: center; gap: 10px;
      font-size: 11px; color: rgba(255,255,255,0.35);
      letter-spacing: 2.5px; text-transform: uppercase;
      margin-bottom: 22px; animation: fadeUp 0.6s 0.05s ease both;
    }
    .hero-since::before, .hero-since::after { content:''; height:1px; width:28px; background:rgba(255,255,255,0.15); }
    h1 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(54px, 7.5vw, 92px); font-weight: 900;
      line-height: 0.93; letter-spacing: -1px; margin-bottom: 22px;
      animation: fadeUp 0.6s 0.1s ease both;
    }
    h1 em { font-style: normal; color: var(--orange); }
    .hero-sub {
      font-size: 16px; font-weight: 300; color: rgba(255,255,255,0.58);
      line-height: 1.75; max-width: 460px; margin-bottom: 36px;
      animation: fadeUp 0.6s 0.15s ease both;
    }

    /* TRACK FORM */
    .track-form { display: flex; flex-direction: column; gap: 10px; animation: fadeUp 0.6s 0.2s ease both; }
    .track-label { font-size: 11px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.35); }
    .input-row { display: flex; }
    .track-input {
      flex: 1; background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12); border-right: none;
      border-radius: 8px 0 0 8px; padding: 15px 18px;
      color: white; font-family: 'DM Sans', sans-serif; font-size: 15px;
      outline: none; transition: border-color 0.2s;
    }
    .track-input::placeholder { color: rgba(255,255,255,0.22); }
    .track-input:focus { border-color: var(--orange); background: rgba(249,115,22,0.05); }
    .track-btn {
      background: var(--orange); color: white; border: none;
      padding: 15px 26px; border-radius: 0 8px 8px 0;
      font-family: 'Barlow Condensed', sans-serif; font-size: 16px;
      font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
      cursor: pointer; transition: background 0.2s; white-space: nowrap;
    }
    .track-btn:hover { background: var(--orange2); }

    /* HERO CTA BUTTONS */
    .hero-btns {
      display: flex; gap: 12px; margin-top: 20px; flex-wrap: wrap;
      animation: fadeUp 0.6s 0.25s ease both;
    }
.hero-btn {
      display: flex; align-items: center; gap: 8px; padding: 11px 20px;
      border-radius: 8px; font-size: 14px; font-weight: 600;
      text-decoration: none; transition: all 0.2s;
    }
    .hero-btn-wa { background: rgba(37,211,102,0.12); border: 1px solid rgba(37,211,102,0.25); color: #25D366; }
    .hero-btn-wa:hover { background: #25D366; color: white; transform: translateY(-2px); }
    .hero-btn-email { background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.25); color: var(--orange); }
    .hero-btn-email:hover { background: var(--orange); color: white; transform: translateY(-2px); }

    /* STATS */
    .stats-bar {
      display: flex; gap: 36px; margin-top: 44px; padding-top: 36px;
      border-top: 1px solid rgba(255,255,255,0.08); flex-wrap: wrap;
      animation: fadeUp 0.6s 0.3s ease both;
    }
    .stat-num { font-family: 'Barlow Condensed', sans-serif; font-size: 34px; font-weight: 800; }
    .stat-num em { font-style: normal; color: var(--orange); }
    .stat-label { font-size: 12px; color: rgba(255,255,255,0.38); margin-top: 2px; }

    /* HERO VISUAL CARDS */
    .hero-visual {
      position: absolute; right: 0; top: 50%; transform: translateY(-50%);
      width: 40%; pointer-events: none; animation: fadeIn 1s 0.5s ease both;
    }
    .hero-card {
      background: rgba(30,41,59,0.85); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px; padding: 22px; backdrop-filter: blur(20px); margin: 10px; width: 290px;
    }
    .hero-card:first-child { margin-left: auto; margin-right: 50px; }
    .hero-card:last-child { margin-left: 40px; }
    .hc-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .hc-tag { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--orange); background: rgba(249,115,22,0.1); padding: 4px 10px; border-radius: 4px; }
    .hc-dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 8px #22c55e; }
    .hc-id { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 700; }
    .hc-route { font-size: 12px; color: rgba(255,255,255,0.45); margin-bottom: 14px; }
    .hc-bar { background: rgba(255,255,255,0.1); border-radius: 4px; height: 4px; }
    .hc-fill { height: 4px; border-radius: 4px; background: var(--orange); }

    /* FEATURES */
    .features { padding: 96px 48px; background: var(--navy2); }
    .sec-label { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--orange); margin-bottom: 14px; }
    .sec-title { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(34px, 4vw, 52px); font-weight: 800; margin-bottom: 52px; line-height: 1.05; }
    .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .fc {
      background: var(--slate); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px; padding: 32px 28px;
      transition: border-color 0.25s, transform 0.25s; position: relative; overflow: hidden;
    }
    .fc::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--orange), transparent); opacity: 0; transition: opacity 0.25s; }
    .fc:hover { border-color: rgba(249,115,22,0.35); transform: translateY(-5px); }
    .fc:hover::before { opacity: 1; }
    .fc-icon { width: 48px; height: 48px; border-radius: 12px; background: rgba(249,115,22,0.12); display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 18px; }
    .fc h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 21px; font-weight: 700; margin-bottom: 10px; }
    .fc p { font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.7; }

    /* CONTACT */
    .contact-sec { padding: 96px 48px; background: var(--navy); }
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; max-width: 1040px; margin: 0 auto; }
    .cl h2 { font-family: 'Barlow Condensed', sans-serif; font-size: 46px; font-weight: 800; line-height: 1; margin-bottom: 14px; }
    .cl h2 em { font-style: normal; color: var(--orange); }
    .cl p { font-size: 15px; color: rgba(255,255,255,0.5); line-height: 1.75; margin-bottom: 28px; }
    .ci { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; font-size: 13px; color: rgba(255,255,255,0.55); }
    .ci-icon { width: 38px; height: 38px; border-radius: 8px; background: rgba(249,115,22,0.1); display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
    .quick-btns { display: flex; flex-direction: column; gap: 10px; margin-top: 22px; }
    .qb {
      display: flex; align-items: center; gap: 12px; padding: 13px 18px;
      border-radius: 10px; font-size: 14px; font-weight: 600;
      text-decoration: none; transition: all 0.2s;
    }
    .qb-wa { background: rgba(37,211,102,0.1); border: 1px solid rgba(37,211,102,0.2); color: #25D366; }
    .qb-wa:hover { background: #25D366; color: white; transform: translateX(5px); }
    .qb-em { background: rgba(249,115,22,0.1); border: 1px solid rgba(249,115,22,0.2); color: var(--orange); }
    .qb-em:hover { background: var(--orange); color: white; transform: translateX(5px); }

    /* FORM */
    .cf { display: flex; flex-direction: column; gap: 14px; }
    .fg { display: flex; flex-direction: column; gap: 6px; }
    .fl { font-size: 11px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: rgba(255,255,255,0.38); }
    .fi {
      width: 100%; background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
      padding: 12px 14px; color: white; font-family: 'DM Sans', sans-serif;
      font-size: 14px; outline: none; transition: border-color 0.2s; -webkit-appearance: none;
    }
    .fi::placeholder { color: rgba(255,255,255,0.18); }
    .fi:focus { border-color: var(--orange); background: rgba(249,115,22,0.04); }
    textarea.fi { resize: vertical; min-height: 120px; }
    .fr { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .sb {
      background: var(--orange); color: white; border: none; padding: 14px;
      border-radius: 8px; font-family: 'Barlow Condensed', sans-serif;
      font-size: 17px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
      cursor: pointer; transition: background 0.2s; width: 100%;
    }
    .sb:hover { background: var(--orange2); }
    .sb:disabled { opacity: 0.6; cursor: not-allowed; }
    .fa { display: none; padding: 12px 16px; border-radius: 8px; font-size: 14px; text-align: center; margin-bottom: 12px; }
    .fa.ok { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: #22c55e; }
    .fa.err { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; }

    /* FOOTER */
    footer { background: #060b14; padding: 60px 48px 32px; border-top: 1px solid rgba(255,255,255,0.06); }
    .footer-top { display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,0.06); margin-bottom: 28px; flex-wrap: wrap; gap: 32px; }
    .fl-logo { font-family: 'Barlow Condensed', sans-serif; font-size: 28px; font-weight: 900; }
    .fl-logo span { color: var(--orange); }
    .fl-sub { font-size: 11px; color: rgba(255,255,255,0.28); margin-top: 4px; letter-spacing: 1.5px; text-transform: uppercase; }
    .footer-links { display: flex; gap: 48px; flex-wrap: wrap; }
    .footer-col h4 { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 14px; }
    .footer-col a { display: block; color: rgba(255,255,255,0.5); text-decoration: none; font-size: 13px; margin-bottom: 10px; transition: color 0.2s; }
    .footer-col a:hover { color: white; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
    .footer-copy { font-size: 12px; color: rgba(255,255,255,0.28); }

    /* WHATSAPP FLOAT */
    .wa-float {
      position: fixed; bottom: 24px; right: 24px; z-index: 300;
      width: 56px; height: 56px; border-radius: 50%;
      background: #25D366; color: white; font-size: 26px;
      display: flex; align-items: center; justify-content: center;
      text-decoration: none; box-shadow: 0 4px 20px rgba(37,211,102,0.45);
      transition: transform 0.2s, box-shadow 0.2s;
      animation: popIn 0.5s 1s ease both;
    }
    .wa-float:hover { transform: scale(1.12); box-shadow: 0 8px 30px rgba(37,211,102,0.55); }
    @keyframes popIn { from{opacity:0;transform:scale(0.4)} to{opacity:1;transform:scale(1)} }

    @keyframes fadeUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeIn { from{opacity:0} to{opacity:1} }

    /* RESPONSIVE */
    @media(max-width:960px) {
      .top-bar { padding: 7px 16px; }
      .top-bar-left { display: none; }
      .nav-inner { padding: 0 20px; }
      .desktop-menu, .nav-wa { display: none; }
      .hamburger { display: flex; }
      .hero { padding: 70px 20px 60px; }
      .hero-visual { display: none; }
      .stats-bar { gap: 20px; }
      .features { padding: 64px 20px; }
      .features-grid { grid-template-columns: 1fr; gap: 16px; }
