<script>
  // ---- MOBILE MENU ----
  function openMenu() {
    document.getElementById('mobileMenu').classList.add('open');
    document.getElementById('overlay').classList.add('open');
    document.getElementById('hamburger').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    document.getElementById('mobileMenu').classList.remove('open');
    document.getElementById('overlay').classList.remove('open');
    document.getElementById('hamburger').classList.remove('open');
    document.body.style.overflow = '';
  }
  function toggleSub(id, btn) {
    document.getElementById(id).classList.toggle('open');
    btn.querySelector('.mm-arrow').classList.toggle('open');
  }

  // ---- CONTACT FORM ----
  document.getElementById('contactForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = this.querySelector('.sb');
    btn.textContent = 'Sending...';
    btn.disabled = true;

    try {
      const res = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          firstName: this.firstName.value,
          lastName: this.lastName.value,
          email: this.email.value,
          subject: this.subject.value,
          trackingNumber: this.trackingNumber.value,
          message: this.message.value
        })
      });
      const r = await res.json();
      if (r.success) {
        document.getElementById('fok').style.display = 'block';
        document.getElementById('ferr').style.display = 'none';
        this.reset();
      } else {
        document.getElementById('ferr').style.display = 'block';
      }
    } catch(err) {
      document.getElementById('ferr').style.display = 'block';
    }
    btn.textContent = 'Send Message →';
    btn.disabled = false;
  });
</script>
